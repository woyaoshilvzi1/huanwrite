# Huanwrite environment template
# Copy this file to .huanwrite/.env and fill real credentials.
# .huanwrite/.env.example may be committed; never commit .huanwrite/.env.

# Active provider settings
# Pick one provider block below, copy it here, and fill HUANWRITE_API_KEY.
HUANWRITE_PROVIDER=yls
HUANWRITE_API_KEY=
HUANWRITE_BASE_URL=https://code.ylsagi.com/codex
HUANWRITE_MODEL=gpt-5.5
HUANWRITE_API_TIMEOUT_MS=60000
HUANWRITE_REASONING_EFFORT=medium
HUANWRITE_SHOW_REASONING=true
HUANWRITE_STREAMING=true
# HUANWRITE_THINKING=enabled

# Provider preset: yls
# HUANWRITE_PROVIDER=yls
# HUANWRITE_API_KEY=replace-with-your-key
# HUANWRITE_BASE_URL=https://code.ylsagi.com/codex
# HUANWRITE_MODEL=gpt-5.5
# HUANWRITE_API_TIMEOUT_MS=60000
# HUANWRITE_REASONING_EFFORT=medium
# HUANWRITE_SHOW_REASONING=true
# HUANWRITE_STREAMING=true

# Provider preset: ttapi
# HUANWRITE_PROVIDER=ttapi
# HUANWRITE_API_KEY=replace-with-your-key
# HUANWRITE_BASE_URL=https://w.ciykj.cn
# HUANWRITE_MODEL=gpt-5.5
# HUANWRITE_API_TIMEOUT_MS=60000
# HUANWRITE_REASONING_EFFORT=medium
# HUANWRITE_SHOW_REASONING=true
# HUANWRITE_STREAMING=true

# Provider preset: deepseekv4
# HUANWRITE_PROVIDER=deepseekv4
# HUANWRITE_API_KEY=replace-with-your-key
# HUANWRITE_BASE_URL=https://api.deepseek.com
# HUANWRITE_MODEL=deepseek-v4-flash
# HUANWRITE_API_TIMEOUT_MS=60000
# HUANWRITE_THINKING=enabled
# HUANWRITE_REASONING_EFFORT=max
# HUANWRITE_SHOW_REASONING=true
# HUANWRITE_STREAMING=true
